{
  "name": "postsnail",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "postsnail": "./bin/postsnail.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "generate:site": "node scripts/generate-public-site.js",
    "build:admin": "node scripts/prepare-admin-assets.js",
    "surge:bridge": "node scripts/snaillift-surge-bridge.js",
    "preview": "npm run build:admin && wrangler dev",
    "deploy": "npm run build:admin && wrangler deploy",
    "deploy:dry-run": "npm run build:admin && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "wrangler": "4.98.0"
  }
}
