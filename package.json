{
  "name": "postsnail",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "postsnail": "./bin/postsnail.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "generate:site": "node scripts/generate-public-site.js",
    "build:editor": "esbuild src/editor/postsnailMarkdownEditor.js --bundle --format=esm --target=es2022 --outfile=vendor/postsnail-editor/editor.bundle.js --minify",
    "build:admin": "node scripts/prepare-admin-assets.js",
    "surge:bridge": "node scripts/snaillift-surge-bridge.js",
    "preview": "npm run build:admin && wrangler dev",
    "deploy": "npm run build:admin && wrangler deploy",
    "deploy:dry-run": "npm run build:admin && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.1",
    "wrangler": "4.98.0"
  }
}
